{
  "name": "GreDež - Vreme Slovenija",
  "short_name": "GreDež",
  "description": "Meteorološki podatki za Ljubljano iz različnih virov",
  "start_url": "/gredez/",
  "display": "standalone",
  "background_color": "#f8f9fa",
  "theme_color": "#0d6efd",
  "scope": "/gredez/",
  "icons": [
    {
      "src": "icon.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "screenshots": [
    {
      "src": "images/screenshot1.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Trenutno stanje"
    }
  ],
  "categories": ["weather", "utilities"],
  "dir": "ltr",
  "lang": "sl",
  "orientation": "portrait",
  "prefer_related_applications": false,
  "display_override": ["standalone", "window-controls-overlay"],
  "launch_handler": {
    "client_mode": ["navigate-existing", "auto"]
  },
  "id": "/gredez/",
  "share_target": {
    "action": "/gredez/",
    "method": "GET",
    "params": {
      "text": "text",
      "url": "url"
    }
  },
  "offline_enabled": true
